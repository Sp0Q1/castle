#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# castlectl (compose edition) — provision castle on a single VPS with Podman/
# Docker Compose + Caddy. The non-Kubernetes counterpart of ../k8s/castlectl.sh;
# same ideas (codename pool, per-tenant Keycloak realm, one shared client
# secret, codename-only — the cluster/host never learns a client's real name).
#
#   castlectl issue-certs [N]       bulk-issue certs for the IdP + N codenames in
#                                   ONE CA batch (the only CT event). No Keycloak
#                                   needed — run this BEFORE bringing up platform.
#   castlectl provision-pool        stand up a canary for every codename that has
#                                   a cert but no instance (platform must be up)
#   castlectl renew-pool            batch-renew the whole pool's certs together
#   castlectl allocate              pick a free codename, issue its cert, canary it
#   castlectl promote <codename>    turn a canary into a real tenant (no new cert)
#   castlectl demote <codename>     turn a tenant back into a canary (cert kept)
#   castlectl deprovision <codename>
#   castlectl list
#
# Canonical bring-up:
#   castlectl issue-certs 10
#   docker compose -f platform.compose.yml up -d
#   castlectl provision-pool
#
# THE CERT STRATEGY: certs for the whole pool are issued once, together, and
# Caddy runs with auto_https off — so promoting a canary to a real tenant
# contacts no CA and leaves no Certificate Transparency trace. An observer sees
# the pool issued in bulk and never learns which codenames became real, or when.
#
# CODENAME-ONLY: no client name is ever taken or stored. You record which client
# a codename belongs to in your own store, off this host.
# ---------------------------------------------------------------------------
set -uo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
cd "$HERE"
[[ -f .env ]] && set -a && . ./.env && set +a

K8S="$HERE/../k8s"
POOL="${POOL:-$K8S/codenames.txt}"           # shared with the k8s path
REALM_SH="${REALM_SH:-$K8S/keycloak-realm.sh}"
TPL="$HERE/templates"
SITES="$HERE/caddy/sites"
CERTS="$HERE/caddy/certs"
RUN="$HERE/.instances"                        # per-codename generated compose files
BASE_DOMAIN="${BASE_DOMAIN:?set BASE_DOMAIN in .env}"
KC_PUBLIC_URL="${KC_PUBLIC_URL:?set KC_PUBLIC_URL in .env}"
# Where castlectl reaches Keycloak's admin API FROM THIS HOST. Same as the
# browser-facing URL in prod; differs only when the public port is a tunnel that
# doesn't exist on the box (e.g. lab: browser :8443 -> box :443), where this is
# the bare :443 host.
KC_ADMIN_URL="${KC_ADMIN_URL:-$KC_PUBLIC_URL}"
KC_REALM_PREFIX="${KC_REALM_PREFIX:-castle-}"
CASTLE_IMAGE="${CASTLE_IMAGE:-ghcr.io/sp0q1/castle:latest}"
ENGINE="${ENGINE:-podman}"
COMPOSE="${COMPOSE:-$ENGINE compose}"
# Cert issuance is dehydrated (pure-bash ACME, matches this script). castlectl
# maintains DOMAINS_TXT (the pool) and collects results; your dehydrated config
# owns the challenge (http-01 webroot / dns-01 hook) and CERTDIR.
DEHYDRATED="${DEHYDRATED:-dehydrated}"
DEHYDRATED_CONFIG="${DEHYDRATED_CONFIG:-$HERE/dehydrated/config}"
DEHYDRATED_CERTDIR="${DEHYDRATED_CERTDIR:-$CERTS/_dehydrated}"
DOMAINS_TXT="$RUN/domains.txt"                # dehydrated's domains.txt = the allocated pool

EXTERNAL_PORT="${EXTERNAL_PORT:-}"   # port in browser-facing URLs (blank = 443)

# --- self-hosted authoritative DNS (Option 3) -----------------------------
# When SELF_HOSTED_DNS is set, castle runs its own nameserver for $BASE_DOMAIN
# (the `dns` service in platform.compose.yml). castlectl then publishes each
# provisioned codename's A record and drives DNS-01 through it, both via RFC 2136
# dynamic updates (nsupdate + a TSIG key). Unset -> castlectl never touches DNS.
SELF_HOSTED_DNS="${SELF_HOSTED_DNS:-}"
PUBLIC_IP="${PUBLIC_IP:-}"                       # VPS public IP for A records
DNS_SERVER="${DNS_SERVER:-127.0.0.1}"            # where nsupdate sends (this box)
DNS_PORT="${DNS_PORT:-53}"
TSIG_NAME="${TSIG_NAME:-castle-ddns}"
TSIG_ALGO="${TSIG_ALGO:-hmac-sha256}"
TSIG_KEYFILE="${TSIG_KEYFILE:-$RUN/ddns.key}"    # nsupdate key, derived from .env

die(){ echo "castlectl: $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null 2>&1 || die "$1 is required but not on PATH"; }
# Bare host — for certs, DNS and Caddy vhost names (no port; a cert is for a
# host, not a host:port).
host_of(){ echo "$1.$BASE_DOMAIN"; }
# Host with the browser-facing port — for OIDC redirect URIs and any URL a
# browser follows. Equal to host_of when EXTERNAL_PORT is unset (prod, 443).
hostport_of(){ echo "$1.$BASE_DOMAIN${EXTERNAL_PORT:+:$EXTERNAL_PORT}"; }
realm_of(){ echo "${KC_REALM_PREFIX}$1"; }
rand(){ openssl rand -base64 "${1:-32}" | tr -d '\n'; }
proj_of(){ echo "castle-$1"; }
mkdir -p "$RUN"

pool_codenames(){ grep -vE '^\s*(#|$)' "$POOL"; }

# SOURCE OF TRUTH = the runtime + the artifacts on disk, never a bookkeeping
# file that could drift from them:
#   - a codename HAS a cert if its cert file exists (the artifact);
#   - it's RUNNING as a tenant/canary if its containers exist (ask the engine).
# The only things genuinely stored are what cannot be re-derived: the per-codename
# secrets and the certs themselves. domains.txt is just dehydrated's INPUT list
# (what to issue), not a claim about what exists.
has_cert(){ [[ -f "$CERTS/$(host_of "$1")/fullchain.pem" ]]; }
container_exists(){ $ENGINE ps -a --format '{{.Names}}' 2>/dev/null | grep -qx "$1"; }
kind_of(){ # tenant | canary | "" — derived from the engine, not a local file
  container_exists "castle-$1" && { echo tenant; return; }
  container_exists "oauth2-proxy-$1" && { echo canary; return; }
  echo ""
}
# next_codename must skip a name that already owns a cert OR is queued for one.
taken(){ has_cert "$1" || grep -qxF "$(host_of "$1")" "$DOMAINS_TXT" 2>/dev/null; }
allocated(){ for cn in $(pool_codenames); do taken "$cn" && echo "$cn"; done; }
add_domain(){ mkdir -p "$RUN"; touch "$DOMAINS_TXT"; grep -qxF "$1" "$DOMAINS_TXT" || echo "$1" >> "$DOMAINS_TXT"; }

next_codename(){
  local free; free="$(comm -23 <(pool_codenames | sort) <(allocated | sort))"
  [[ -n "$free" ]] || die "codename pool exhausted — add names to $(basename "$POOL")"
  echo "$free" | shuf -n 1
}

# --- self-hosted DNS (Option 3) -------------------------------------------
# The nsupdate key file is derived from DDNS_TSIG_SECRET in .env — the SAME
# secret the `dns` service loads — so both sides share one key. Written 0600 and
# never committed (it lives under .instances/, which is git-ignored).
ensure_tsig_keyfile(){
  [[ -n "${DDNS_TSIG_SECRET:-}" ]] || die "SELF_HOSTED_DNS set but DDNS_TSIG_SECRET missing in .env (run: castlectl dns-init)"
  [[ -f "$TSIG_KEYFILE" ]] && return 0
  ( umask 077
    printf 'key "%s" {\n    algorithm %s;\n    secret "%s";\n};\n' \
      "$TSIG_NAME" "$TSIG_ALGO" "$DDNS_TSIG_SECRET" > "$TSIG_KEYFILE" )
}
# Send RFC 2136 update commands (on stdin) to our authoritative server.
dns_nsupdate(){
  nsupdate -k "$TSIG_KEYFILE" <<EOF
server $DNS_SERVER $DNS_PORT
zone $BASE_DOMAIN.
$(cat)
send
EOF
}
dns_set_a(){ # <codename> — point the codename at this box (idempotent)
  [[ -n "$SELF_HOSTED_DNS" ]] || return 0
  need nsupdate; ensure_tsig_keyfile
  [[ -n "$PUBLIC_IP" ]] || die "SELF_HOSTED_DNS set but PUBLIC_IP missing in .env"
  local host; host="$(host_of "$1")"
  printf 'update delete %s. A\nupdate add %s. 300 A %s\n' "$host" "$host" "$PUBLIC_IP" \
    | dns_nsupdate || die "nsupdate A for $host failed"
}
dns_del_a(){ # <codename> — remove the A record (goes dark)
  [[ -n "$SELF_HOSTED_DNS" ]] || return 0
  need nsupdate; ensure_tsig_keyfile
  local host; host="$(host_of "$1")"
  printf 'update delete %s. A\n' "$host" | dns_nsupdate || true
}

# --- certificates ---------------------------------------------------------
# One batch over the WHOLE pool (domains.txt), not per-host: dehydrated issues
# the missing certs and renews the near-expiry ones together, which is exactly
# the "one CA event, one CT batch, synchronized renewal" property. This is the
# only place a cert is ever obtained, and promoting a canary never re-enters it.
# Your dehydrated config owns the challenge type + CERTDIR; castlectl only
# supplies the domains and copies the results into Caddy's cert dir.
sync_certs(){
  touch "$DOMAINS_TXT"
  if [[ -n "${KC_INSECURE:-}" ]]; then          # lab: self-signed, never touch a CA
    while read -r host; do [[ -n "$host" ]] && mock_cert "$host"; done < "$DOMAINS_TXT"
    return
  fi
  need "$DEHYDRATED"
  # With self-hosted DNS, dehydrated's DNS-01 hook (dns-hook.sh) talks to our own
  # nameserver over nsupdate; export the key + server it needs.
  local -a hook_env=()
  if [[ -n "$SELF_HOSTED_DNS" ]]; then
    ensure_tsig_keyfile
    hook_env=(DNS_SERVER="$DNS_SERVER" DNS_PORT="$DNS_PORT" TSIG_KEYFILE="$TSIG_KEYFILE")
  fi
  # dehydrated reads its DOMAINS_TXT + CERTDIR from the config file (see
  # dehydrated/config.example); castlectl passes the same DOMAINS_TXT via env so
  # the config can point at it. -c = cron mode: issue missing + renew due, all
  # in one run.
  DOMAINS_TXT="$DOMAINS_TXT" CERTDIR="$DEHYDRATED_CERTDIR" "${hook_env[@]}" \
    "$DEHYDRATED" ${DEHYDRATED_CONFIG:+-f "$DEHYDRATED_CONFIG"} -c ${DEHYDRATED_ARGS:-} \
    || die "dehydrated failed"
  while read -r host; do
    [[ -n "$host" ]] || continue
    install -m600 -D "$DEHYDRATED_CERTDIR/$host/fullchain.pem" "$CERTS/$host/fullchain.pem"
    install -m600 -D "$DEHYDRATED_CERTDIR/$host/privkey.pem"  "$CERTS/$host/privkey.pem"
  done < "$DOMAINS_TXT"
}

# Lab-only self-signed stand-in so the whole flow is testable without a CA.
mock_cert(){ # <host>
  local host="$1"; local d="$CERTS/$host"; mkdir -p "$d"
  openssl req -x509 -newkey rsa:2048 -nodes -keyout "$d/privkey.pem" \
    -out "$d/fullchain.pem" -days 90 -subj "/CN=$host" \
    -addext "subjectAltName=DNS:$host" >/dev/null 2>&1
}

# --- Caddy vhosts ---------------------------------------------------------
write_site(){ # <codename>
  local cn="$1" host; host="$(host_of "$cn")"
  sed -e "s/__HOST__/$host/g" -e "s/__CODENAME__/$cn/g" \
    "$TPL/site.caddy" > "$SITES/$cn.caddy"
}
reload_caddy(){ $COMPOSE -f platform.compose.yml exec -T caddy caddy reload --config /etc/caddy/Caddyfile 2>/dev/null \
  || $COMPOSE -f platform.compose.yml restart caddy >/dev/null 2>&1 || true; }

# --- provision a canary / tenant -----------------------------------------
# Only STRUCTURAL placeholders are sed'd in (codename/realm/host/image — all safe
# chars). Secrets are NOT written into the rendered file; they are injected from
# the environment at compose time (compose_instance), so base64 `/`/`+` never
# breaks sed and no secret lands on disk in a compose file.
render_instance(){ # <codename> <template>
  local cn="$1" tpl="$2"
  local realm host hostport
  realm="$(realm_of "$cn")"; host="$(host_of "$cn")"; hostport="$(hostport_of "$cn")"
  sed -e "s/__CODENAME__/$cn/g" -e "s/__REALM__/$realm/g" -e "s#__HOST__#$host#g" \
      -e "s#__HOSTPORT__#$hostport#g" \
      -e "s#__KC_PUBLIC__#$KC_PUBLIC_URL#g" -e "s#__IMAGE__#${CASTLE_IMAGE//\//\\/}#g" \
      "$tpl" > "$RUN/$cn.compose.yml"
}


# Run a compose command for a codename with its secrets exported, so compose
# substitutes ${OAP_*}/${CASTLE_*} from the environment. The DB password is hex
# (URL-safe in DATABASE_URL); JWT stays base64 (loco decodes it).
compose_instance(){ # <codename> <compose args...>
  local cn="$1"; shift
  OAP_CLIENT_SECRET="$(secret_for "$cn")" \
  OAP_COOKIE_SECRET="$(cookie_for "$cn")" \
  CASTLE_JWT="$(ensure_secret "$cn" jwt 48)" \
  CASTLE_DB_PW="$(ensure_secret "$cn" db 24 hex)" \
    $COMPOSE -p "$(proj_of "$cn")" -f "$RUN/$cn.compose.yml" "$@"
}

provision_canary(){ # <codename>
  local cn="$1"
  [[ "$cn" =~ ^[a-z][a-z0-9-]{1,30}$ ]] || die "invalid codename '$cn'"
  echo "canary '$cn' -> https://$(host_of "$cn")"
  # A canary realm: created empty (keycloak-realm.sh makes users:[]), events on.
  KC_URL="$KC_ADMIN_URL" KC_REALM_PREFIX="$KC_REALM_PREFIX" BASE_DOMAIN="$BASE_DOMAIN" EXTERNAL_PORT="$EXTERNAL_PORT" \
    CLIENT_SECRET="$(secret_for "$cn")" "$REALM_SH" create "$cn" >/dev/null 2>&1 || die "realm create failed"
  render_instance "$cn" "$TPL/canary.compose.yml"
  write_site "$cn"
  compose_instance "$cn" up -d >/dev/null 2>&1 || die "compose up failed"
  dns_set_a "$cn"     # publish the A record (no-op unless SELF_HOSTED_DNS)
  echo "  ok (canary)"
}

# Per-codename secrets are generated once and cached, so the realm's client
# secret and the oauth2-proxy's stay in lockstep across canary<->tenant swaps.
secret_for(){ ensure_secret "$1" client 32; }
cookie_for(){ ensure_secret "$1" cookie 16 hex; }
ensure_secret(){ # <codename> <name> <bytes> [hex]
  local f="$RUN/$1.$2"; [[ -f "$f" ]] && { cat "$f"; return; }
  local v; if [[ "${4:-}" == hex ]]; then v="$(openssl rand -hex "$3")"; else v="$(rand "$3")"; fi
  printf '%s' "$v" > "$f"; printf '%s' "$v"
}

# --- commands -------------------------------------------------------------
# The single controlled CA interaction: issue the IdP cert + N codename certs in
# one batch. No Keycloak or platform required — this runs first, so the certs
# exist before Caddy starts. CT shows them appearing together.
issue_certs(){ # [N]
  need openssl
  local n="${1:-10}" cn picked=()
  # The self-hosted nameserver is authoritative for $BASE_DOMAIN only, so it
  # answers DNS-01 for the codename pool but not for an IdP host on another apex.
  # That's fine: Caddy auto-manages the IdP (sso) cert itself via ACME — nothing
  # to issue here. See docs/self-hosted-dns.md.
  if [[ -n "$SELF_HOSTED_DNS" && "$KC_HOST" != *".$BASE_DOMAIN" ]]; then
    echo "note: pool certs only; the IdP cert for $KC_HOST is auto-managed by Caddy." >&2
    echo "adding $n codenames to the pool, then one batch issuance"
  else
    echo "adding IdP + $n codenames to the pool, then one batch issuance"
    add_domain "$KC_HOST"
  fi
  for _ in $(seq 1 "$n"); do
    cn="$(next_codename)"; picked+=("$cn")   # next_codename skips names already in the pool
    add_domain "$(host_of "$cn")"
  done
  sync_certs
  echo "issued for: ${picked[*]}"
  echo "next: bring up platform, then 'castlectl provision-pool'"
}

# Stand up a canary for every codename that has a cert but isn't provisioned yet.
# Idempotent — safe to re-run. Platform (Keycloak) must be up.
provision_pool(){
  local done_any=0
  # Every codename that has a cert but isn't running yet -> stand up a canary.
  for cn in $(pool_codenames); do
    has_cert "$cn" || continue
    [[ -n "$(kind_of "$cn")" ]] && continue      # already running (asked the engine)
    provision_canary "$cn"; done_any=1
  done
  [[ "$done_any" == 1 ]] && reload_caddy
  echo "pool provisioned."
}

renew_pool(){
  echo "batch-renewing the whole pool's certs together (one dehydrated run)"
  sync_certs      # dehydrated -c renews everything in domains.txt that's due
  reload_caddy
  echo "renewed."
}

promote(){ # <codename>
  local cn="${1:?promote needs a <codename>}"
  [[ "$(kind_of "$cn")" == canary ]] || die "'$cn' is not a canary"
  echo "promoting canary '$cn' -> real tenant (cert + subdomain + realm unchanged)"
  compose_instance "$cn" down >/dev/null 2>&1
  render_instance "$cn" "$TPL/tenant.compose.yml"
  compose_instance "$cn" up -d >/dev/null 2>&1 || die "compose up failed"
  echo "  ok (tenant) — now add the client's users to realm $(realm_of "$cn")"
}

demote(){ # <codename> — back to a canary; keeps the cert and realm
  local cn="${1:?demote needs a <codename>}"
  [[ "$(kind_of "$cn")" == tenant ]] || die "'$cn' is not a tenant"
  echo "demoting tenant '$cn' -> canary (cert kept; DATA IS DESTROYED)"
  compose_instance "$cn" down -v >/dev/null 2>&1
  provision_canary "$cn"; reload_caddy
}

deprovision(){ # <codename>
  local cn="${1:?deprovision needs a <codename>}"
  echo "deprovisioning '$cn'"
  [[ -f "$RUN/$cn.compose.yml" ]] && compose_instance "$cn" down -v >/dev/null 2>&1
  dns_del_a "$cn"     # withdraw the A record (no-op unless SELF_HOSTED_DNS)
  KC_URL="$KC_ADMIN_URL" KC_REALM_PREFIX="$KC_REALM_PREFIX" "$REALM_SH" delete "$cn" >/dev/null 2>&1 || true
  rm -f "$SITES/$cn.caddy" "$RUN/$cn".{compose.yml,client,cookie,jwt,db}
  reload_caddy
  echo "  removed (cert left in place for reuse)"
}

list(){
  printf '%-16s %-9s %s\n' CODENAME STATE URL
  # Reflect reality: a codename appears if it's running (engine) or has a cert.
  for cn in $(pool_codenames); do
    local state; state="$(kind_of "$cn")"
    if [[ -z "$state" ]]; then has_cert "$cn" && state="cert-only" || continue; fi
    printf '%-16s %-9s %s\n' "$cn" "$state" "https://$(host_of "$cn")"
  done
}

# allocate = issue one cert + provision it as a canary (platform must be up).
allocate(){ local cn; cn="$(next_codename)"; add_domain "$(host_of "$cn")"; sync_certs; provision_canary "$cn"; reload_caddy; }

# --- self-hosted DNS commands ---------------------------------------------
# Generate the shared TSIG secret. Print it for .env (the `dns` service and
# castlectl both read DDNS_TSIG_SECRET from there — one secret, two consumers).
dns_init(){
  need openssl
  local secret; secret="$(openssl rand -base64 32)"
  cat <<EOF
Generated a DDNS TSIG secret. Add it to .env (used by the dns service AND castlectl):

  SELF_HOSTED_DNS=1
  PUBLIC_IP=<this VPS's public IP>
  DDNS_TSIG_SECRET=$secret

Then delegate $BASE_DOMAIN to this box (NS + glue) at your registrar, open :53,
and start the platform with the self-dns profile:

  $COMPOSE -f platform.compose.yml --profile self-dns up -d

Full walkthrough: docs/self-hosted-dns.md
EOF
}
# Reconcile the zone with reality: A record for every running codename, nothing
# for the rest. The runtime is the source of truth (same principle as `list`).
dns_sync(){
  [[ -n "$SELF_HOSTED_DNS" ]] || die "SELF_HOSTED_DNS is not set in .env"
  need nsupdate; ensure_tsig_keyfile
  local cn n=0
  for cn in $(pool_codenames); do
    if [[ -n "$(kind_of "$cn")" ]]; then dns_set_a "$cn"; n=$((n+1)); else dns_del_a "$cn"; fi
  done
  echo "dns synced: $n running codename(s) -> $PUBLIC_IP; dark codenames withdrawn"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  issue-certs)     issue_certs "${1:-10}" ;;
  provision-pool)  provision_pool ;;
  renew-pool)      renew_pool ;;
  allocate)        allocate ;;
  promote)         promote "${1:-}" ;;
  demote)          demote "${1:-}" ;;
  deprovision)     deprovision "${1:-}" ;;
  list)            list ;;
  dns-init)        dns_init ;;
  dns-sync)        dns_sync ;;
  *) echo "usage: castlectl {issue-certs [N]|provision-pool|renew-pool|allocate|promote <cn>|demote <cn>|deprovision <cn>|list|dns-init|dns-sync}"; exit 1 ;;
esac
