# Copy to .env and fill in. .env is git-ignored.

# The domain codenames live under. Subdomains are <codename>.$BASE_DOMAIN.
BASE_DOMAIN=tenants.example.com

# The IdP host (its own subdomain, its own pre-issued cert).
KC_HOST=sso.example.com
KC_PUBLIC_URL=https://sso.example.com

# Keycloak first-boot admin (rotate to a named MFA admin after setup).
KC_ADMIN_USER=admin
KC_ADMIN_PASS=change-me-strong

# Keycloak's database password.
KC_DB_PASSWORD=change-me-strong

# The published castle image (built + signed by CI).
CASTLE_IMAGE=ghcr.io/sp0q1/castle:latest

# Cert issuance is dehydrated (see dehydrated/config.example). Override if your
# dehydrated binary/config live elsewhere:
# DEHYDRATED=dehydrated
# DEHYDRATED_CONFIG=./dehydrated/config
# DEHYDRATED_CERTDIR=./caddy/certs/_dehydrated
ACME_EMAIL=ops@example.com   # (used by the dehydrated config's CONTACT_EMAIL)

# Container engine: "docker" or "podman".
ENGINE=podman

# Accept a self-signed IdP cert for realm creation — LOCAL LAB ONLY.
# KC_INSECURE=1
