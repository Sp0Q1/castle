**/config/local.yaml
**/config/*.local.yaml
# NOTE: config/production.yaml IS committed (it holds the SSO/proxy config and
# references all real secrets via env vars). Keep secrets out of it — use env.

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# include cargo lock
!Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

*.sqlite
*.sqlite-*

# Runtime-uploaded images
uploads/