# The IdP vhost. Unlike the codename pool (which pins pre-issued certs), the IdP
# is always-on and not a decoy, so Caddy manages its cert itself via ACME
# (HTTP-01 / TLS-ALPN-01) over its permanent listeners and renews it
# automatically — no dehydrated, no pre-issue, no manual step.
# {$KC_HOST} is substituted from the environment when Caddy starts.
{$KC_HOST} {
	reverse_proxy keycloak:8080
}
